# Copy to .env and fill in. Only ADMIN_PASSWORD is required.

# Required to expose the /admin page (basic auth; username ignored).
ADMIN_PASSWORD=change-me

# Optional: enable FCM push alerts (use the same Firebase project as the app).
# Omit all three to run without push (flood shutoff + state caching still work).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Where the JSON db lives (default ./data/brvg.json).
DB_PATH=./data/brvg.json
PORT=3030
